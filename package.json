{
  "private": true,
  "type": "module",
  "scripts": {
    "fmt": "prettier --write ./**/*.{js,ts,vue,md,html,css}",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "cleanup": "nuxt cleanup",
    "start": "node .output/server/index.mjs",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@nuxt/content": "^3.13.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@takumi-rs/core": "^1.1.2",
    "better-sqlite3": "^12.9.0",
    "nuxt": "^4.4.2",
    "nuxt-og-image": "^6.4.8",
    "nuxt-security": "^2.5.1",
    "sitemap": "^9.0.1"
  },
  "devDependencies": {
    "@iconify-json/bi": "^1.2.7",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/simple-icons": "^1.2.80",
    "@unocss/nuxt": "^66.6.8",
    "prettier": "^3.8.3",
    "prettier-plugin-mdc": "^0.2.1",
    "typescript": "^6.0.3",
    "unocss": "^66.6.8",
    "vue-tsc": "^3.2.7"
  },
  "engines": {
    "node": ">=22.x"
  },
  "prettier": {
    "printWidth": 120,
    "proseWrap": "always",
    "plugins": [
      "prettier-plugin-mdc"
    ],
    "overrides": [
      {
        "files": [
          "*.md"
        ],
        "options": {
          "parser": "mdc"
        }
      }
    ]
  },
  "overrides": {
    "@rollup/plugin-terser": "1.0.0"
  }
}
